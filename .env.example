# ============================================================
# CLI .env — App-specific variables
# ============================================================
# Loaded automatically by dotenv when the CLI starts.
# Copy to .env and fill in values for local development.

# Orchestrator URL — where the CLI sends API requests (login, register, status)
# ORCHESTRATOR_URL=http://localhost:3000

# Portal URL — where the CLI opens the browser for authentication
# PORTAL_URL=http://localhost:3001
